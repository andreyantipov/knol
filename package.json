{
  "name": "meta.txt",
  "version": "0.1.0",
  "description": "Minimal markdown docs viewer — bunx meta.txt and browse .md files in your project",
  "type": "module",
  "bin": {
    "meta.txt": "bin/meta.ts"
  },
  "files": [
    "bin",
    "src",
    "ui/dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev:ui": "cd ui && bun run dev",
    "dev:server": "bun run --watch bin/meta.ts",
    "build:ui": "cd ui && bun run build",
    "build:bin": "bun build --compile --target=bun --outfile=dist/meta bin/meta.ts",
    "build": "bun run build:ui && bun run build:bin",
    "start": "bun run bin/meta.ts",
    "release": "bun run build:ui && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andreyantipov/meta.txt.git"
  },
  "keywords": [
    "markdown",
    "docs",
    "viewer",
    "cli"
  ],
  "author": "Andrey Antipov",
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
